# ===================================================================
# CONDADO +VACAS — Variables de entorno
# Copia este archivo a .env.local y rellena los valores.
# ===================================================================

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase (Auth + Storage)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_AUTH_WEBHOOK_SECRET=

# Base de datos (Supabase Postgres)
# DATABASE_URL: conexión pooled (PgBouncer) para Prisma en serverless
# DIRECT_URL: conexión directa para migraciones
DATABASE_URL=
DIRECT_URL=

# Stripe (pagos + payouts a RRPP vía Connect Express)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=        # `stripe listen` en dev, endpoint secret en prod
STRIPE_CONNECT_CLIENT_ID=     # ca_... (producción)
STRIPE_TEST_ACCOUNT_ID=       # acct_... destino de transfers en modo test

# Email (Resend)
RESEND_API_KEY=
EMAIL_FROM="Condado +vacas <hola@condado.gal>"

# SMS (Twilio) — Fase 2, opcional. Desactivado por defecto.
ENABLE_SMS=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Mapbox (vista mapa del calendario RRPP)
NEXT_PUBLIC_MAPBOX_TOKEN=

# Firma de tokens QR (HMAC)
QR_SECRET=
